      "html": "<style data-kid=\"0\">\n  @import url('https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@700,800&f[]=satoshi@400,500,700&display=swap');\n\n  :root {\n    --color-rose-accent: #E11D48;\n    --color-zinc-900: #18181b;\n    --color-warm-bg: #FAF9F7;\n    --font-heading: 'Cabinet Grotesk', sans-serif;\n    --font-body: 'Satoshi', sans-serif;\n  }\n\n  body {\n    background-color: var(--color-warm-bg);\n    color: var(--color-zinc-900);\n    font-family: var(--font-body);\n    margin: 0;\n  }\n\n  .font-heading { font-family: var(--font-heading); }\n  \n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-auto-rows: minmax(100px, auto);\n    gap: 1.5rem;\n  }\n\n  .diffuse-shadow {\n    box-shadow: 0 20px 50px -12px rgba(24, 24, 27, 0.08);\n  }\n\n  .rose-glow {\n    box-shadow: 0 0 40px -10px rgba(225, 29, 72, 0.15);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(24, 24, 27, 0.05);\n  }\n\n  .animate-reveal {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n</style>\n\n\n<nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50 w-full max-w-4xl px-4\" data-kid=\"1\">\n  <div class=\"glass-card rounded-full px-8 py-3 flex items-center justify-between diffuse-shadow\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-8 h-8 rounded bg-[var(--color-zinc-900)] flex items-center justify-center font-heading font-bold text-sm text-white\" data-kid=\"4\">R</div>\n      <span class=\"font-heading font-bold text-lg tracking-tight\" data-kid=\"5\">Register</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8 text-sm font-medium opacity-70\" data-kid=\"6\">\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"7\">Expertise</a>\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"8\">Portfolio</a>\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"9\">Processus</a>\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"10\">Contact</a>\n    </div>\n    <button class=\"bg-[var(--color-rose-accent)] text-white px-5 py-2 rounded-full text-sm font-bold active:scale-95 transition-transform hover:brightness-110\" data-kid=\"11\">\n      Audit gratuit\n    </button>\n  </div>\n</nav>\n\n\n<main class=\"relative pt-40 pb-32 px-6 max-w-7xl mx-auto overflow-hidden\" data-kid=\"12\">\n  <div class=\"grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"13\">\n    \n    <div class=\"z-10\" data-kid=\"14\">\n      <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-rose-accent)]/10 text-[var(--color-rose-accent)] text-xs font-bold uppercase tracking-widest mb-6\" data-kid=\"15\">\n        <span class=\"relative flex h-2 w-2\" data-kid=\"16\">\n          <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-rose-accent)] opacity-75\" data-kid=\"17\"></span>\n          <span class=\"relative inline-flex rounded-full h-2 w-2 bg-[var(--color-rose-accent)]\" data-kid=\"18\"></span>\n        </span>\n        Artisanat Numérique\n      </div>\n      <h1 class=\"font-heading text-6xl lg:text-8xl font-extrabold leading-[0.9] tracking-tighter mb-8 animate-reveal\" style=\"opacity: 1; transform: none;\" data-kid=\"19\">\n        Design web <br data-kid=\"20\"> \n        <span class=\"text-[var(--color-rose-accent)]\" data-kid=\"21\">haute-couture.</span>\n      </h1>\n      <p class=\"text-lg lg:text-xl text-[var(--color-zinc-900)]/70 leading-relaxed mb-10 max-w-lg animate-reveal\" style=\"opacity: 1; transform: none; transition-delay: 100ms;\" data-kid=\"22\">\n        Nous transformons votre vision artisanale en une expérience digitale d'élite. Conception sur-mesure pour les bâtisseurs de demain.\n      </p>\n      \n      <div class=\"flex flex-col sm:flex-row gap-4 animate-reveal\" style=\"opacity: 1; transform: none; transition-delay: 200ms;\" data-kid=\"23\">\n        <div class=\"relative flex-grow max-w-md\" data-kid=\"24\">\n          <input type=\"email\" placeholder=\"votre@email.fr\" class=\"w-full h-14 rounded-full px-8 bg-white/50 border border-[var(--color-zinc-900)]/10 focus:outline-none focus:border-[var(--color-rose-accent)] transition-colors diffuse-shadow\" data-kid=\"25\">\n          <button class=\"absolute right-1.5 top-1.5 h-11 px-8 rounded-full bg-[var(--color-zinc-900)] text-white font-bold text-sm active:scale-95 transition-transform\" data-kid=\"26\">\n            Démarrer\n          </button>\n        </div>\n      </div>\n      \n      <div class=\"mt-12 flex items-center gap-4 opacity-50 grayscale hover:grayscale-0 transition-all duration-500\" data-kid=\"27\">\n        <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"28\">Ils nous font confiance :</span>\n        <div class=\"flex gap-6 font-heading font-extrabold text-sm\" data-kid=\"29\">\n          <span data-kid=\"30\">MAISON LEMAIRE</span>\n          <span data-kid=\"31\">ATELIER BROUSSARD</span>\n          <span data-kid=\"32\">TRANS-VAL</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"relative grid grid-cols-2 gap-4 h-[500px]\" data-kid=\"33\">\n      \n      <div class=\"col-span-1 row-span-2 glass-card rounded-[2.5rem] p-8 flex flex-col justify-between diffuse-shadow animate-reveal\" style=\"opacity: 1; transform: none; transition-delay: 300ms;\" data-kid=\"34\">\n        <div class=\"w-12 h-12 rounded-2xl bg-[var(--color-rose-accent)]/10 flex items-center justify-center\" data-kid=\"35\">\n          <i class=\"lucide-trending-up w-6 h-6 text-[var(--color-rose-accent)]\" data-kid=\"36\"></i>\n        </div>\n        <div data-kid=\"37\">\n          <div class=\"text-5xl font-heading font-extrabold mb-1 tracking-tighter\" data-kid=\"38\">+38.4%</div>\n          <p class=\"text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"39\">Croissance moyenne du CA</p>\n          <div class=\"mt-6 h-20 w-full flex items-end gap-1\" data-kid=\"40\">\n            <div class=\"flex-grow bg-[var(--color-rose-accent)]/20 rounded-t-sm h-[40%]\" data-kid=\"41\"></div>\n            <div class=\"flex-grow bg-[var(--color-rose-accent)]/30 rounded-t-sm h-[60%]\" data-kid=\"42\"></div>\n            <div class=\"flex-grow bg-[var(--color-rose-accent)]/50 rounded-t-sm h-[45%]\" data-kid=\"43\"></div>\n            <div class=\"flex-grow bg-[var(--color-rose-accent)] rounded-t-sm h-[100%]\" data-kid=\"44\"></div>\n          </div>\n        </div>\n      </div>\n      \n      \n      <div class=\"glass-card rounded-[2.5rem] p-8 diffuse-shadow flex flex-col justify-center animate-reveal\" style=\"opacity: 1; transform: none; transition-delay: 400ms;\" data-kid=\"45\">\n        <div class=\"text-4xl font-heading font-extrabold mb-1 tracking-tighter\" data-kid=\"46\">0.74s</div>\n        <p class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"47\">Temps de chargement LCP</p>\n        <div class=\"mt-4 flex items-center gap-1\" data-kid=\"48\">\n          <div class=\"h-1 w-full bg-emerald-500 rounded-full\" data-kid=\"49\"></div>\n          <div class=\"text-[10px] font-bold text-emerald-600\" data-kid=\"50\">OPTIMAL</div>\n        </div>\n      </div>\n      \n      \n      <div class=\"glass-card rounded-[2.5rem] p-8 diffuse-shadow flex flex-col justify-center animate-reveal\" style=\"opacity: 1; transform: none; transition-delay: 500ms;\" data-kid=\"51\">\n        <div class=\"text-4xl font-heading font-extrabold mb-1 tracking-tighter\" data-kid=\"52\">-12.5h</div>\n        <p class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"53\">Gestion administrative / semaine</p>\n        <div class=\"mt-4 flex items-center -space-x-2\" data-kid=\"54\">\n          <div class=\"w-6 h-6 rounded-full border-2 border-white bg-zinc-200\" data-kid=\"55\"></div>\n          <div class=\"w-6 h-6 rounded-full border-2 border-white bg-zinc-300\" data-kid=\"56\"></div>\n          <div class=\"w-6 h-6 rounded-full border-2 border-white bg-zinc-400\" data-kid=\"57\"></div>\n          <div class=\"pl-4 text-[10px] font-bold opacity-40\" data-kid=\"58\">+Automatisé</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</main>\n\n\n<section class=\"py-32 px-6 max-w-7xl mx-auto\" data-kid=\"59\">\n  <div class=\"flex flex-col md:flex-row justify-between items-end mb-16\" data-kid=\"60\">\n    <div class=\"max-w-xl\" data-kid=\"61\">\n      <h2 class=\"font-heading text-4xl lg:text-5xl font-extrabold tracking-tighter mb-6\" data-kid=\"62\">Un processus sculpté <br data-kid=\"63\"> pour votre réussite.</h2>\n      <p class=\"text-[var(--color-zinc-900)]/60 text-lg\" data-kid=\"64\">Nous ne construisons pas seulement des sites. Nous bâtissons des infrastructures de croissance pérennes.</p>\n    </div>\n    <div class=\"mt-8 md:mt-0\" data-kid=\"65\">\n      <div class=\"text-sm font-bold uppercase tracking-widest opacity-30\" data-kid=\"66\">Artisans du pixel</div>\n    </div>\n  </div>\n\n  <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"67\">\n    \n    <div class=\"md:col-span-2 glass-card rounded-[3rem] p-12 diffuse-shadow relative overflow-hidden group\" data-kid=\"68\">\n      <div class=\"relative z-10 max-w-md\" data-kid=\"69\">\n        <h3 class=\"font-heading text-3xl font-bold mb-4\" data-kid=\"70\">Analyse de Trajectoire</h3>\n        <p class=\"text-[var(--color-zinc-900)]/60 leading-relaxed mb-8\" data-kid=\"71\">Nous auditons vos flux actuels pour identifier les goulots d'étranglement qui freinent votre transformation digitale.</p>\n        <ul class=\"space-y-3\" data-kid=\"72\">\n          <li class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"73\">\n            <i class=\"lucide-check w-4 h-4 text-[var(--color-rose-accent)]\" data-kid=\"74\"></i> Audit technique approfondi\n          </li>\n          <li class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"75\">\n            <i class=\"lucide-check w-4 h-4 text-[var(--color-rose-accent)]\" data-kid=\"76\"></i> Cartographie des opportunités\n          </li>\n        </ul>\n      </div>\n      <div class=\"absolute -right-20 -bottom-20 w-80 h-80 rounded-full bg-[var(--color-rose-accent)]/5 blur-3xl group-hover:bg-[var(--color-rose-accent)]/10 transition-colors duration-700\" data-kid=\"77\"></div>\n    </div>\n\n    \n    <div class=\"glass-card rounded-[3rem] p-12 diffuse-shadow flex flex-col justify-between\" data-kid=\"78\">\n      <div class=\"w-12 h-12 rounded-2xl bg-[var(--color-zinc-900)] flex items-center justify-center\" data-kid=\"79\">\n        <i class=\"lucide-layers w-6 h-6 text-white\" data-kid=\"80\"></i>\n      </div>\n      <div data-kid=\"81\">\n        <h3 class=\"font-heading text-2xl font-bold mb-3\" data-kid=\"82\">Fondations Évolutives</h3>\n        <p class=\"text-sm text-[var(--color-zinc-900)]/60 leading-relaxed\" data-kid=\"83\">Une architecture Next.js pensée pour tenir 10 ans, pas 10 mois.</p>\n      </div>\n    </div>\n\n    \n    <div class=\"glass-card rounded-[3rem] p-12 diffuse-shadow flex flex-col justify-between\" data-kid=\"84\">\n      <div class=\"w-12 h-12 rounded-2xl bg-[var(--color-rose-accent)] flex items-center justify-center\" data-kid=\"85\">\n        <i class=\"lucide-shield-check w-6 h-6 text-white\" data-kid=\"86\"></i>\n      </div>\n      <div data-kid=\"87\">\n        <h3 class=\"font-heading text-2xl font-bold mb-3\" data-kid=\"88\">Sécurité & Support</h3>\n        <p class=\"text-sm text-[var(--color-zinc-900)]/60 leading-relaxed\" data-kid=\"89\">Accompagnement VIP post-lancement pour garantir votre sérénité totale.</p>\n      </div>\n    </div>\n\n    \n    <div class=\"md:col-span-2 glass-card rounded-[3rem] p-12 diffuse-shadow flex flex-col md:flex-row gap-12 items-center\" data-kid=\"90\">\n      <div class=\"flex-grow\" data-kid=\"91\">\n        <h3 class=\"font-heading text-3xl font-bold mb-4\" data-kid=\"92\">Étude de Cas : Maison Lemaire</h3>\n        <p class=\"text-[var(--color-zinc-900)]/60 leading-relaxed mb-6\" data-kid=\"93\">\"Le carnet de commandes a triplé en 3 mois grâce au nouveau référencement local.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"94\">\n          <div class=\"w-10 h-10 rounded-full bg-zinc-200\" data-kid=\"95\"></div>\n          <div data-kid=\"96\">\n            <div class=\"text-sm font-bold\" data-kid=\"97\">Grégory Lemaire</div>\n            <div class=\"text-[10px] uppercase font-bold opacity-40\" data-kid=\"98\">Maître Ébéniste</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"w-full md:w-64 aspect-video bg-[var(--color-zinc-900)]/5 rounded-2xl border border-[var(--color-zinc-900)]/10 flex items-center justify-center\" data-kid=\"99\">\n        <i class=\"lucide-play w-10 h-10 text-[var(--color-rose-accent)]\" data-kid=\"100\"></i>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-6 bg-[var(--color-zinc-900)] text-white rounded-[4rem] mx-6\" data-kid=\"101\">\n  <div class=\"max-w-5xl mx-auto text-center mb-20\" data-kid=\"102\">\n    <h2 class=\"font-heading text-5xl lg:text-7xl font-extrabold tracking-tighter mb-6\" data-kid=\"103\">Investissement <span class=\"text-[var(--color-rose-accent)]\" data-kid=\"104\">clair.</span></h2>\n    <p class=\"text-white/60 text-lg max-w-xl mx-auto\" data-kid=\"105\">Pas d'abonnement caché. Un prix fixe pour une excellence durable.</p>\n  </div>\n\n  <div class=\"grid md:grid-cols-2 gap-8 max-w-4xl mx-auto\" data-kid=\"106\">\n    \n    <div class=\"p-12 rounded-[3rem] border border-white/10 hover:border-[var(--color-rose-accent)]/50 transition-colors duration-500\" data-kid=\"107\">\n      <h3 class=\"font-heading text-3xl font-bold mb-2\" data-kid=\"108\">Essentiel</h3>\n      <p class=\"text-white/40 text-sm mb-8\" data-kid=\"109\">Idéal pour les artisans et PME</p>\n      <div class=\"text-5xl font-heading font-extrabold mb-10 tracking-tighter\" data-kid=\"110\">Sur mesure</div>\n      <ul class=\"space-y-4 mb-12\" data-kid=\"111\">\n        <li class=\"flex items-center gap-3 text-sm opacity-80\" data-kid=\"112\"><i class=\"lucide-check w-4 h-4 text-emerald-400\" data-kid=\"113\"></i> Design sur-mesure</li>\n        <li class=\"flex items-center gap-3 text-sm opacity-80\" data-kid=\"114\"><i class=\"lucide-check w-4 h-4 text-emerald-400\" data-kid=\"115\"></i> Optimisation SEO local</li>\n        <li class=\"flex items-center gap-3 text-sm opacity-80\" data-kid=\"116\"><i class=\"lucide-check w-4 h-4 text-emerald-400\" data-kid=\"117\"></i> Hébergement ultra-rapide</li>\n      </ul>\n      <button class=\"w-full py-4 rounded-full border border-white/20 font-bold hover:bg-white hover:text-[var(--color-zinc-900)] transition-all\" data-kid=\"118\">Nous contacter</button>\n    </div>\n\n    \n    <div class=\"p-12 rounded-[3rem] bg-[var(--color-rose-accent)] text-white diffuse-shadow relative overflow-hidden group\" data-kid=\"119\">\n      <div class=\"absolute top-8 right-8 text-[10px] font-bold uppercase tracking-widest bg-white/20 px-3 py-1 rounded-full\" data-kid=\"120\">Elite</div>\n      <h3 class=\"font-heading text-3xl font-bold mb-2\" data-kid=\"121\">Signature</h3>\n      <p class=\"text-white/70 text-sm mb-8\" data-kid=\"122\">Pour les projets complexes</p>\n      <div class=\"text-5xl font-heading font-extrabold mb-10 tracking-tighter\" data-kid=\"123\">Sur mesure</div>\n      <ul class=\"space-y-4 mb-12\" data-kid=\"124\">\n        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"125\"><i class=\"lucide-check w-4 h-4 text-white\" data-kid=\"126\"></i> Architecture applicative</li>\n        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"127\"><i class=\"lucide-check w-4 h-4 text-white\" data-kid=\"128\"></i> Espace client dédié</li>\n        <li class=\"flex items-center gap-3 text-sm\" data-kid=\"129\"><i class=\"lucide-check w-4 h-4 text-white\" data-kid=\"130\"></i> Maintenance préventive 24/7</li>\n      </ul>\n      <button class=\"w-full py-4 rounded-full bg-white text-[var(--color-rose-accent)] font-bold active:scale-95 transition-transform shadow-lg\" data-kid=\"131\">Lancer le projet</button>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-40 px-6 text-center\" data-kid=\"132\">\n  <div class=\"max-w-3xl mx-auto rose-glow p-12 lg:p-24 rounded-[4rem] bg-white border border-[var(--color-rose-accent)]/10\" data-kid=\"133\">\n    <h2 class=\"font-heading text-5xl lg:text-7xl font-extrabold tracking-tighter mb-8 leading-none\" data-kid=\"134\">Prêt à sculpter votre <span class=\"text-[var(--color-rose-accent)]\" data-kid=\"135\">succès ?</span></h2>\n    <p class=\"text-lg text-[var(--color-zinc-900)]/60 mb-12 leading-relaxed\" data-kid=\"136\">Rejoignez le cercle restreint des entreprises qui maîtrisent leur image numérique.</p>\n    <div class=\"flex flex-col sm:flex-row justify-center gap-6\" data-kid=\"137\">\n      <button class=\"bg-[var(--color-zinc-900)] text-white px-10 py-5 rounded-full font-bold text-lg active:scale-95 transition-transform diffuse-shadow\" data-kid=\"138\">\n        Réserver mon audit\n      </button>\n      <button class=\"bg-white text-[var(--color-zinc-900)] border border-[var(--color-zinc-900)]/10 px-10 py-5 rounded-full font-bold text-lg hover:bg-[var(--color-warm-bg)] transition-colors\" data-kid=\"139\">\n        Découvrir nos œuvres\n      </button>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 px-6 border-t border-[var(--color-zinc-900)]/5\" data-kid=\"140\">\n  <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12\" data-kid=\"141\">\n    <div class=\"flex items-center gap-2\" data-kid=\"142\">\n      <div class=\"w-8 h-8 rounded bg-[var(--color-zinc-900)] flex items-center justify-center font-heading font-bold text-sm text-white\" data-kid=\"143\">R</div>\n      <span class=\"font-heading font-bold text-lg tracking-tight\" data-kid=\"144\">Register</span>\n    </div>\n    <div class=\"flex gap-8 text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"145\">\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"146\">Légal</a>\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"147\">Confidentialité</a>\n      <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"148\">Presse</a>\n    </div>\n    <div class=\"text-[10px] font-bold opacity-30\" data-kid=\"149\">\n      © 2026 REGISTER AGENCY. ARTISANAT NUMÉRIQUE.\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"150\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"151\"></script>\n<script data-kid=\"152\">\n  lucide.createIcons();\n  \n  // Minimal animation trigger\n  gsap.from(\".animate-reveal\", {\n    y: 30,\n    opacity: 0,\n    duration: 1,\n    stagger: 0.15,\n    ease: \"power4.out\",\n    delay: 0.5\n  });\n</script>",
