      "html": "<style data-kid=\"0\">\n  @import url('https://api.fontshare.com/v2/css?f[]=clash-display@200,300,400,500,600,700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/mono.css');\n\n  body {\n    background-color: #09090b;\n    color: #f8fafc;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-clash { font-family: 'Clash Display', sans-serif; }\n  .font-mono { font-family: 'Geist Mono', monospace; }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .glass-blue {\n    background: rgba(37, 99, 235, 0.05);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(37, 99, 235, 0.2);\n  }\n\n  .glow-blue {\n    box-shadow: 0 0 30px -10px rgba(37, 99, 235, 0.5);\n  }\n\n  .text-gradient {\n    background: linear-gradient(135deg, #f8fafc 0%, #94a3b8 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .kinetic-border {\n    position: relative;\n    overflow: hidden;\n  }\n\n  .kinetic-border::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -50%;\n    width: 200%;\n    height: 200%;\n    background: conic-gradient(from 0deg, transparent, #2563eb, transparent 30%);\n    animation: rotate 4s linear infinite;\n    z-index: -1;\n  }\n\n  @keyframes rotate {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n\n  .hero-blob {\n    position: absolute;\n    width: 500px;\n    height: 500px;\n    background: radial-gradient(circle, rgba(37, 99, 235, 0.15) 0%, transparent 70%);\n    filter: blur(60px);\n    z-index: -1;\n  }\n</style>\n\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n  \n  <div class=\"hero-blob top-[-10%] left-[-10%]\" data-kid=\"2\"></div>\n  <div class=\"hero-blob bottom-[20%] right-[-10%] opacity-50\" data-kid=\"3\"></div>\n\n  \n  <nav class=\"fixed top-6 left-1/2 -translate-x-1/2 w-[90%] max-w-6xl glass rounded-full px-8 py-4 flex items-center justify-between z-50\" data-kid=\"4\">\n    <div class=\"flex items-center gap-3\" data-kid=\"5\">\n      <div class=\"w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center font-clash font-bold text-white shadow-[0_0_15px_rgba(37,99,235,0.4)]\" data-kid=\"6\">R</div>\n      <span class=\"font-clash font-semibold tracking-wide text-xl\" data-kid=\"7\">Register</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-slate-400\" data-kid=\"8\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Services</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"10\">Portfolio</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Process</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"12\">Expertise</a>\n    </div>\n    <button class=\"bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-full font-semibold text-sm transition-all active:scale-95 shadow-[0_0_20px_rgba(37,99,235,0.3)]\" data-kid=\"13\">\n      Let's Build\n    </button>\n  </nav>\n\n  \n  <section class=\"pt-48 pb-32 px-6 max-w-7xl mx-auto grid lg:grid-cols-12 gap-16 items-center\" data-kid=\"14\">\n    <div class=\"lg:col-span-7\" id=\"hero-content\" data-kid=\"15\">\n      <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full glass border-blue-500/20 text-xs font-mono text-blue-400 mb-8\" data-kid=\"16\">\n        <span class=\"relative flex h-2 w-2\" data-kid=\"17\">\n          <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75\" data-kid=\"18\"></span>\n          <span class=\"relative inline-flex rounded-full h-2 w-2 bg-blue-500\" data-kid=\"19\"></span>\n        </span>\n        V3.0 ENGINE ACTIVE\n      </div>\n      <h1 class=\"text-6xl md:text-8xl font-clash font-bold leading-[0.9] tracking-tighter mb-8 text-gradient\" data-kid=\"20\">\n        CODE THE<br data-kid=\"21\"><span class=\"text-blue-600 italic\" data-kid=\"22\">IMPOSSIBLE.</span>\n      </h1>\n      <p class=\"text-slate-400 text-lg md:text-xl leading-relaxed mb-12 max-w-xl\" data-kid=\"23\">\n        High-performance architectures for digital artisans. We build the infrastructure that scales your vision from concept to market authority.\n      </p>\n      \n      <div class=\"flex flex-col sm:flex-row gap-4\" data-kid=\"24\">\n        <div class=\"relative group\" data-kid=\"25\">\n          <div class=\"absolute -inset-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000 group-hover:duration-200\" data-kid=\"26\"></div>\n          <button class=\"relative bg-black text-white px-10 py-4 rounded-full font-bold flex items-center gap-2 group\" data-kid=\"27\">\n            START PROJECT\n            <svg class=\"w-5 h-5 group-hover:translate-x-1 transition-transform\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"28\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\" data-kid=\"29\"></path></svg>\n          </button>\n        </div>\n        <button class=\"glass px-10 py-4 rounded-full font-bold hover:bg-white/5 transition-colors\" data-kid=\"30\">\n          OUR STACK\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"lg:col-span-5 relative h-[500px]\" id=\"hero-cards\" data-kid=\"31\">\n      \n      <div class=\"absolute top-0 right-0 w-64 glass-blue p-6 rounded-2xl rotate-3 floating-card\" style=\"--d: 0s\" data-kid=\"32\">\n        <div class=\"font-mono text-blue-400 text-xs mb-4\" data-kid=\"33\">PERFORMANCE_METRIC</div>\n        <div class=\"text-4xl font-clash font-bold mb-1\" data-kid=\"34\">0.64s</div>\n        <div class=\"text-slate-400 text-xs\" data-kid=\"35\">LCP OPTIMIZED</div>\n        <div class=\"mt-4 h-1 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"36\">\n          <div class=\"h-full bg-blue-500 w-[94%]\" data-kid=\"37\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-10 left-0 w-72 glass p-6 rounded-2xl -rotate-6 floating-card\" style=\"--d: 1s\" data-kid=\"38\">\n        <div class=\"flex items-center gap-3 mb-4\" data-kid=\"39\">\n          <div class=\"w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600\" data-kid=\"40\"></div>\n          <div data-kid=\"41\">\n            <div class=\"text-sm font-bold\" data-kid=\"42\">Pixel Artisan</div>\n            <div class=\"text-[10px] text-slate-500 font-mono\" data-kid=\"43\">CORE_DEVELOPER</div>\n          </div>\n        </div>\n        <div class=\"text-xs text-slate-400 leading-relaxed italic\" data-kid=\"44\">\n          \"The architecture is seamless. Scaling to 1M+ requests without a single drop in frame rate.\"\n        </div>\n      </div>\n\n      \n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 glass p-4 rounded-xl shadow-2xl floating-card\" style=\"--d: 0.5s\" data-kid=\"45\">\n        <div class=\"flex justify-between items-center mb-2\" data-kid=\"46\">\n          <span class=\"text-[10px] font-mono text-slate-500\" data-kid=\"47\">UPTIME</span>\n          <span class=\"text-[10px] font-mono text-emerald-400\" data-kid=\"48\">LIVE</span>\n        </div>\n        <div class=\"text-2xl font-clash font-bold\" data-kid=\"49\">99.98%</div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-20 border-y border-white/5 overflow-hidden\" data-kid=\"50\">\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"51\">\n      <p class=\"text-[10px] font-mono text-slate-600 uppercase tracking-[0.3em] mb-12 text-center\" data-kid=\"52\">Engineered for Industry Leaders</p>\n      <div class=\"flex flex-wrap justify-center gap-x-16 gap-y-8 opacity-40 grayscale hover:grayscale-0 transition-all duration-700\" data-kid=\"53\">\n        <span class=\"text-xl font-clash font-bold tracking-widest\" data-kid=\"54\">QUANTUM_DEV</span>\n        <span class=\"text-xl font-clash font-bold tracking-widest\" data-kid=\"55\">NEURAL_SYNC</span>\n        <span class=\"text-xl font-clash font-bold tracking-widest\" data-kid=\"56\">VOID_LABS</span>\n        <span class=\"text-xl font-clash font-bold tracking-widest\" data-kid=\"57\">CORE_LOGIC</span>\n        <span class=\"text-xl font-clash font-bold tracking-widest\" data-kid=\"58\">AXON_MEDIA</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6 max-w-7xl mx-auto\" data-kid=\"59\">\n    <div class=\"grid md:grid-cols-12 gap-6 h-[700px]\" data-kid=\"60\">\n      <div class=\"md:col-span-8 glass rounded-[2.5rem] p-12 relative overflow-hidden group bento-item\" data-kid=\"61\">\n        <div class=\"relative z-10 h-full flex flex-col justify-between\" data-kid=\"62\">\n          <div data-kid=\"63\">\n            <h3 class=\"text-4xl font-clash font-bold mb-4\" data-kid=\"64\">Atomic Design Systems</h3>\n            <p class=\"text-slate-400 max-w-md\" data-kid=\"65\">We build modular component libraries that evolve with your product. Future-proof from line one.</p>\n          </div>\n          <div class=\"mt-8 flex gap-4\" data-kid=\"66\">\n             <div class=\"px-4 py-2 rounded-lg glass-blue font-mono text-[10px] text-blue-400\" data-kid=\"67\">REACT_19</div>\n             <div class=\"px-4 py-2 rounded-lg glass-blue font-mono text-[10px] text-blue-400\" data-kid=\"68\">TAILWIND_V4</div>\n             <div class=\"px-4 py-2 rounded-lg glass-blue font-mono text-[10px] text-blue-400\" data-kid=\"69\">FRAMER_MOTION</div>\n          </div>\n        </div>\n        <div class=\"absolute bottom-[-10%] right-[-5%] w-1/2 aspect-video bg-blue-600/20 blur-3xl group-hover:scale-125 transition-transform duration-1000\" data-kid=\"70\"></div>\n      </div>\n\n      <div class=\"md:col-span-4 glass rounded-[2.5rem] p-12 bento-item\" data-kid=\"71\">\n        <div class=\"w-16 h-16 rounded-2xl bg-blue-600 flex items-center justify-center mb-8 glow-blue\" data-kid=\"72\">\n          <svg class=\"w-8 h-8 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"73\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" data-kid=\"74\"></path></svg>\n        </div>\n        <h3 class=\"text-2xl font-clash font-bold mb-4\" data-kid=\"75\">Edge Infrastructure</h3>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"76\">Deployment across 300+ global nodes for sub-100ms latency globally.</p>\n      </div>\n\n      <div class=\"md:col-span-4 glass rounded-[2.5rem] p-12 bento-item\" data-kid=\"77\">\n        <h3 class=\"text-2xl font-clash font-bold mb-4\" data-kid=\"78\">Organic Growth</h3>\n        <div class=\"text-5xl font-clash font-bold text-blue-500 mb-2\" data-kid=\"79\">+47.2%</div>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"80\">Average SEO conversion uplift within 90 days of launch.</p>\n      </div>\n\n      <div class=\"md:col-span-8 glass rounded-[2.5rem] p-12 relative overflow-hidden bento-item\" data-kid=\"81\">\n         <div class=\"flex items-center justify-between mb-8\" data-kid=\"82\">\n            <h3 class=\"text-3xl font-clash font-bold\" data-kid=\"83\">Real-time Telemetry</h3>\n            <div class=\"px-4 py-1 rounded-full bg-emerald-500/10 text-emerald-400 font-mono text-[10px]\" data-kid=\"84\">ACTIVE_MONITORING</div>\n         </div>\n         <div class=\"space-y-4\" data-kid=\"85\">\n            <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"86\"><div class=\"h-full bg-blue-500 w-[85%]\" data-kid=\"87\"></div></div>\n            <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"88\"><div class=\"h-full bg-blue-500 w-[60%] opacity-50\" data-kid=\"89\"></div></div>\n            <div class=\"h-2 w-full bg-slate-800 rounded-full overflow-hidden\" data-kid=\"90\"><div class=\"h-full bg-blue-500 w-[92%]\" data-kid=\"91\"></div></div>\n         </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-6\" data-kid=\"92\">\n    <div class=\"max-w-5xl mx-auto glass rounded-[3rem] p-16 md:p-24 text-center relative overflow-hidden\" data-kid=\"93\">\n      <div class=\"absolute inset-0 bg-blue-600/5 pointer-events-none\" data-kid=\"94\"></div>\n      <h2 class=\"text-5xl md:text-7xl font-clash font-bold mb-8 leading-none\" data-kid=\"95\">READY TO<br data-kid=\"96\"><span class=\"text-blue-600 italic\" data-kid=\"97\">TRANSCEND?</span></h2>\n      <p class=\"text-slate-400 text-lg mb-12 max-w-2xl mx-auto\" data-kid=\"98\">\n        Stop building pages. Start building protocols. Join the next generation of digital excellence.\n      </p>\n      <div class=\"flex flex-col sm:flex-row justify-center gap-6\" data-kid=\"99\">\n        <button class=\"bg-blue-600 text-white px-12 py-5 rounded-full font-bold text-lg hover:bg-blue-500 transition-all active:scale-95 glow-blue\" data-kid=\"100\">\n          INITIALIZE AUDIT\n        </button>\n        <button class=\"glass px-12 py-5 rounded-full font-bold text-lg hover:bg-white/10 transition-colors\" data-kid=\"101\">\n          VIEW PORTFOLIO\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 px-6 border-t border-white/5\" data-kid=\"102\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"103\">\n      <div class=\"flex items-center gap-3\" data-kid=\"104\">\n        <div class=\"w-6 h-6 rounded bg-blue-600 flex items-center justify-center font-clash font-bold text-[10px] text-white\" data-kid=\"105\">R</div>\n        <span class=\"font-clash font-semibold text-lg\" data-kid=\"106\">Register</span>\n      </div>\n      <div class=\"flex gap-12 text-sm font-mono text-slate-500\" data-kid=\"107\">\n        <a href=\"#\" class=\"hover:text-blue-400 transition-colors\" data-kid=\"108\">PRIVACY_PROTOCOL</a>\n        <a href=\"#\" class=\"hover:text-blue-400 transition-colors\" data-kid=\"109\">TERMS_OF_SERVICE</a>\n        <a href=\"#\" class=\"hover:text-blue-400 transition-colors\" data-kid=\"110\">SYSTEM_STATUS</a>\n      </div>\n      <div class=\"text-[10px] font-mono text-slate-700\" data-kid=\"111\">\n        © 2026 REGISTER_AGENCY // ALL_RIGHTS_RESERVED\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js\" data-kid=\"112\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js\" data-kid=\"113\"></script>\n\n<script data-kid=\"114\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Floating Animation\n  gsap.to(\".floating-card\", {\n    y: \"random(-20, 20)\",\n    x: \"random(-10, 10)\",\n    rotation: \"random(-2, 2)\",\n    duration: \"random(2, 4)\",\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\",\n    stagger: {\n      amount: 1,\n      from: \"random\"\n    }\n  });\n\n  // Scroll Reveals\n  gsap.from(\"#hero-content > *\", {\n    y: 50,\n    opacity: 0,\n    duration: 1,\n    stagger: 0.2,\n    ease: \"power4.out\"\n  });\n\n  gsap.from(\".bento-item\", {\n    scrollTrigger: {\n      trigger: \".bento-item\",\n      start: \"top 80%\",\n    },\n    y: 100,\n    opacity: 0,\n    duration: 1.2,\n    stagger: 0.1,\n    ease: \"expo.out\"\n  });\n\n  // Kinetic Mouse Parallax for Hero Cards\n  document.addEventListener(\"mousemove\", (e) => {\n    const { clientX, clientY } = e;\n    const centerX = window.innerWidth / 2;\n    const centerY = window.innerHeight / 2;\n    const moveX = (clientX - centerX) / 50;\n    const moveY = (clientY - centerY) / 50;\n\n    gsap.to(\"#hero-cards\", {\n      x: moveX,\n      y: moveY,\n      duration: 1,\n      ease: \"power2.out\"\n    });\n  });\n</script>",
